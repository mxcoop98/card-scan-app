{
  "expo": {
    "name": "Card Tracker",
    "slug": "card-tracker",
    "version": "1.0.0",
    "description": "Personal Pokémon and sports card tracking — scan, catalog, grade, bundle, list to eBay.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Card Tracker",
      "shortName": "Cards",
      "themeColor": "#4a9eff",
      "backgroundColor": "#ffffff",
      "meta": {
        "description": "Personal Pokémon and sports card tracking — scan, catalog, grade, bundle, list to eBay.",
        "og:title": "Card Tracker",
        "og:description": "Scan cards, track value over time, calculate grading ROI, bundle low-value cards into lots, publish to eBay.",
        "og:type": "website",
        "og:url": "https://card-scan-app.vercel.app",
        "twitter:card": "summary"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
