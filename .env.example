DATABASE_URL=postgres://postgres:postgres@localhost:5432/cardtracker
PORT=3000
# optional, raises PokemonTCG.io rate limits (free key from https://dev.pokemontcg.io)
POKEMONTCG_API_KEY=

# eBay Sell API integration
# 1. Sign up at https://developer.ebay.com/
# 2. Create an app in the Developer Console → get client_id (App ID) + client_secret (Cert ID)
# 3. Register a Redirect URL that matches EBAY_REDIRECT_URI below.
#    For sandbox: http://localhost:3000/api/ebay/callback is allowed.
#    For production: must be HTTPS.
EBAY_ENV=sandbox                                                    # or 'production'
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=http://localhost:3000/api/ebay/callback
# RuName (aka "eBay Redirect URL name") — required for OAuth 2.0. Find
# it in Developer Console → your app → User Tokens. Looks like:
#   Firstname_Lastname-Blah-Blah-xxxxxxx
# It's what eBay wants in the OAuth redirect_uri parameter, NOT the URL.
EBAY_RUNAME=
# Space-separated list of Sell API scopes we need.
EBAY_SCOPES=https://api.ebay.com/oauth/api_scope https://api.ebay.com/oauth/api_scope/sell.inventory https://api.ebay.com/oauth/api_scope/sell.account https://api.ebay.com/oauth/api_scope/sell.fulfillment
